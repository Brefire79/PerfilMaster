# ProfileAI — AMB FUSI | Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commite o arquivo .env.local no git!

# ============================================================
# SUPABASE (obrigatório)
# Encontre em: https://app.supabase.com → Settings → API
# ============================================================
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_publica_aqui

# ============================================================
# Exemplo de valores reais (substitua pelos seus):
# VITE_SUPABASE_URL=https://xyzabcdef.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ============================================================

# NOTA: A Anthropic API Key fica no lado do servidor (Edge Function),
# configurada diretamente nas variáveis de ambiente do Supabase.
# Acesse: Supabase Dashboard → Edge Functions → Manage secrets
# Nome da secret: ANTHROPIC_API_KEY
