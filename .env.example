# ProfileAI Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ─── Application Configuration ────────────────────────────────────────────────
VITE_APP_NAME=ProfileAI
# VITE_APP_URL: domínio PÚBLICO do app — usado para montar os links enviados ao
# aluno (WhatsApp /avaliacao/:token, /resultado/:token, convites /join e e-mails).
# Em produção (Netlify) defina o domínio real; em dev pode deixar vazio que o
# código cai para https://perfilmaster.netlify.app automaticamente (src/lib/appUrl.js).
VITE_APP_URL=https://perfilmaster.netlify.app
VITE_APP_ENV=development

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_ENABLE_ANALYTICS=false

# ─── Supabase Configuration (database layer) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional table mapping (if your table names are different)
VITE_SB_TABLE_USERS=app_users
VITE_SB_TABLE_GROUPS=app_groups
VITE_SB_TABLE_MODULES=app_modules
VITE_SB_TABLE_ASSESSMENTS=app_assessments
VITE_SB_TABLE_PROFILES=app_profiles
VITE_SB_TABLE_INVITES=app_invites
VITE_SB_TABLE_SESSOES=app_sessoes
VITE_SB_TABLE_AVALIADOS=app_avaliados
VITE_SB_TABLE_SESSAO_RESPOSTAS=app_sessao_respostas
VITE_SB_TABLE_GROUP_REPORTS=app_group_reports

# ─── Supabase Edge Functions (server-side secrets) ────────────────────────────
# Configure in Supabase project secrets (NOT in frontend .env.local):
# AI_API_KEY=...               (DeepSeek — mesma chave usada no Netlify)
# SUPABASE_SERVICE_ROLE_KEY=...

# ─── IA (DeepSeek) — Netlify Function only (NUNCA no frontend) ───────────────
# A chave fica SOMENTE nas variáveis de ambiente do Netlify (deploy UI ou CLI).
# NUNCA colocar no .env.local nem no bundle do frontend — é uma chave SECRETA.
# Obtenha em: https://platform.deepseek.com/api_keys
# Configurar: Netlify → Site Settings → Environment variables → Add variable
#   (ou via CLI: netlify env:set AI_API_KEY "sk-...")
AI_API_KEY=sk-sua-chave-deepseek-aqui

# Opcionais (têm padrão no código):
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_MODEL=deepseek-chat

# Compatibilidade: a função aceita também DEEPSEEK_API_KEY como nome alternativo
# da mesma chave. DeepSeek é o ÚNICO provedor de IA configurado.
